# Demo / deployment config.
# Load with:  vite build --mode demo
# or:         vite --mode demo      (dev server)
#
# Replace the URL below with your deployed backend (e.g., AWS Lambda API Gateway,
# Azure App Service, ngrok tunnel). Leave empty to force the frontend to fall
# back to the default `http://localhost:5000` and fail fast when no backend is
# running.
VITE_SERVER_URL=https://copilot-hackethon.onrender.com
