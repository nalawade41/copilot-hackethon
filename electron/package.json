{
  "name": "copilot-dicom-viewer",
  "version": "0.0.1",
  "private": true,
  "description": "Copilot DICOM Viewer — Electron desktop app with PACS integration",
  "author": "EAssist",
  "main": "dist/main.cjs",
  "scripts": {
    "build:main": "esbuild src/main.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/main.cjs",
    "build:preload": "esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs",
    "build:electron": "npm run build:main && npm run build:preload",
    "build:web": "cd ../web && npm run build",
    "copy:renderer": "node scripts/copy-renderer.js",
    "build:all": "npm run build:web && npm run copy:renderer && npm run build:electron",
    "dev": "npm run build:electron && electron .",
    "pack:mac": "npm run build:all && electron-builder --mac",
    "pack:win": "npm run build:all && electron-builder --win",
    "pack:all": "npm run build:all && electron-builder --mac --win",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.eassist.copilot-dicom",
    "productName": "Copilot DICOM Viewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*"
    ],
    "icon": "icons/icon.png",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.medical"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "electron": "^32.2.5",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "packageManager": "yarn@1.22.21+sha512.ca75da26c00327d26267ce33536e5790f18ebd53266796fbb664d2a4a5116308042dd8ee7003b276a20eace7d3c5561c3577bdd71bcb67071187af124779620a",
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
